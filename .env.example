# Supabase — get these from Project Settings → API in the Supabase dashboard.
# The two NEXT_PUBLIC_* values are safe to expose to the browser; the anon key is
# protected by row-level security. Copy this file to .env.local and fill it in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, bypasses RLS. Used by webhooks (e.g. Stripe).
# NEVER prefix this with NEXT_PUBLIC_ and never expose it to the browser.
# SUPABASE_SERVICE_ROLE_KEY=
